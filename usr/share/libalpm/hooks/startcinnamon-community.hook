[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = usr/share/xsessions/cinnamon.desktop
Target = usr/share/xsessions/cinnamon2d.desktop
Target = usr/share/wayland-sessions/cinnamon-wayland.desktop
Target = usr/bin/startcinnamon-community

[Action]
Description = Replace cinnamon-session with startcinnamon-community
When = PostTransaction
Exec = /usr/share/libalpm/scripts/startcinnamon-community
